<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Алгоритм Хаффмана"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите текст"
            app:hintTextColor="@color/white"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:hint="Например: hello world"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сжать"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Результат сжатия:"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/compressedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#2ECC71"
            android:textSize="14sp"
            android:background="#16213E"
            android:padding="8dp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/compressionRatio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#F1C40F"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <!-- Таблица частот -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Таблица частот и кодов:"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/freqRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#16213E"
            android:padding="8dp"
            android:layout_marginTop="4dp"
            android:nestedScrollingEnabled="false"/>

        <!-- Декодирование (проверка) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Декодированный текст (проверка):"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/decodedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="#16213E"
            android:padding="8dp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</ScrollView>